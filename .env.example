# === LearnPath-KG Environment Variables ===

# Neo4j (REQUIRED: change password before deployment)
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_learnpath2026

# Optional: LLM API Key (for profile collector)
# Leave empty to use static questionnaire fallback
LLM_API_KEY=

# LLM API Base URL (OpenAI-compatible endpoint)
# Examples:
#   OpenAI:      https://api.openai.com/v1
#   Azure:       https://your-resource.openai.azure.com/openai/deployments/your-model/v1
#   Local Ollama: http://host.docker.internal:11434/v1
#   DeepSeek:    https://api.deepseek.com/v1
#   Moonshot:    https://api.moonshot.cn/v1
LLM_BASE_URL=https://api.openai.com/v1

# LLM Model name
# Examples: gpt-3.5-turbo, gpt-4o-mini, deepseek-chat, moonshot-v1-8k, qwen-turbo
LLM_MODEL=gpt-3.5-turbo

# Optional: Search API Key (Tavily)
# Leave empty to skip search feature
SEARCH_API_KEY=

# Optional: CORS Origins
CORS_ORIGINS=["http://localhost:8080","http://localhost","http://localhost:80"]
