{
  "name": "learnpath-frontend",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "perf:knowledge": "vitest run src/views/Knowledge/index.spec.ts",
    "perf:bundle": "npm run build && node scripts/check-bundle-budget.mjs",
    "perf": "npm run perf:knowledge && npm run perf:bundle"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "cytoscape": "^3.29.0",
    "element-plus": "^2.6.0",
    "pinia": "^2.1.0",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@element-plus/icons-vue": "^2.3.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^29.0.2",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.5",
    "vue-tsc": "^2.0.0"
  }
}
